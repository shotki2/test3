[Unit]
Description=test3 backend
After=network.target mysql.service

[Service]
User=ubuntu
WorkingDirectory=/srv/test3/backend
EnvironmentFile=/srv/test3/backend/.env
ExecStart=/srv/test3/backend/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
